def main(argv: list[str]) -> int:
    if len(argv) < 2 or argv[0] != "profile":
        print("Usage: lain5g profile list|show|configure|validate|diff|apply|restore [profile]", file=sys.stderr)
        return 2
    project_root = Path(os.environ.get("LAIN5G_PROJECT_ROOT", Path(__file__).resolve().parent))
    service = ProfileConfigService(SimpleNamespace(project_root=project_root))
    action = argv[1]
    profile_id = argv[2] if len(argv) > 2 else ""
    try:
        if action == "list":
            for item in service.list_profiles():
                print(item["profile"])
            return 0
        if not profile_id:
            print("Missing profile id", file=sys.stderr)
            return 2
        if action == "show":
            print(json.dumps(service.get_profile(profile_id), indent=2, sort_keys=True))
            return 0
        if action == "validate":
            result = service.validate_profile(profile_id)
            _print_validation(result)
            return 0 if result["valid"] else 1
        if action == "diff":
            for item in service.diff_profile(profile_id)["files"]:
                if item["changed"]:
                    print(item["diff"], end="")
            return 0
        if action == "configure":
            profile = service.get_profile(profile_id)
            for path, label in FIELDS[profile_id]:
                current = _get(profile, path)
                raw = input(f"{label} [{_prompt_value(current)}]: ").strip()
                if raw:
                    _set(profile, path, _coerce(raw, current))
            updated = service.update_profile(profile_id, profile)
            print(json.dumps(updated, indent=2, sort_keys=True))
            return 0
        if action == "apply":
            validation = service.validate_profile(profile_id)
            _print_validation(validation)
            if not validation["valid"]:
                return 1
            diff = service.diff_profile(profile_id)
            changed = [item for item in diff["files"] if item["changed"]]
            print(f"{len(changed)} files will be modified.")
            answer = input("Apply changes? [y/N] ").strip().lower()
            if answer not in {"y", "yes"}:
                print("Aborted.")
                return 1
            print(json.dumps(service.apply_profile(profile_id), indent=2, sort_keys=True))
            return 0
        if action == "restore":
            print(json.dumps(service.restore_profile(profile_id), indent=2, sort_keys=True))
            return 0
    except ProfileConfigError as exc:
        print(f"{exc.code}: {exc.message}", file=sys.stderr)
        return 1 if exc.status_code < 500 else 2
    except ValueError as exc:
        print(f"INVALID_INPUT: {exc}", file=sys.stderr)
        return 2
    print(f"Unknown action: {action}", file=sys.stderr)
    return 2


def _print_validation(result: dict) -> None:
    if result["valid"]:
        print("Configuration valid.")
    else:
        print("Configuration invalid.")
        for error in result["errors"]:
            print(f"- {error}")


def _get(data: dict, path: str):
    value = data
    for part in path.split("."):
        if not isinstance(value, dict) or part not in value:
            return None
        value = value[part]
    return value


def _set(data: dict, path: str, value) -> None:
    current = data
    parts = path.split(".")
    for part in parts[:-1]:
        current = current[part]
    current[parts[-1]] = value


def _prompt_value(value) -> str:
    if value is None:
        return ""
    if value is True:
        return "yes"
    if value is False:
        return "no"
    return str(value)


def _coerce(raw: str, current):
    lowered = raw.lower()
    if isinstance(current, bool):
        if lowered in {"y", "yes", "true", "1"}:
            return True
        if lowered in {"n", "no", "false", "0"}:
            return False
        raise ValueError(f"Expected yes/no for boolean field, got: {raw}")
    if lowered in {"yes", "true"}:
        return True
    if lowered in {"no", "false"}:
        return False
    if current is None:
        return _coerce_number(raw)
    if isinstance(current, int):
        value = _coerce_number(raw)
        return value if isinstance(value, (int, float)) else raw
    if lowered == "null":
        return None
    return raw


def _coerce_number(raw: str):
    if raw.isdigit():
        return int(raw)
    try:
        return float(raw)
    except ValueError:
        return raw


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
