# Copy to .env.app and set this to the absolute host path of this repository.
# It must match the path seen by the host Docker daemon because the backend
# controls deployments/5g-sa/docker-compose.yml through /var/run/docker.sock.
LAIN5G_PROJECT_ROOT=/absolute/path/to/Lain5G-Lab

LAIN5G_SCENARIO=5g-sa
LAIN5G_DRY_RUN=false
LAIN5G_COMMAND_TIMEOUT=300
LAIN5G_IMAGE_PULL_TIMEOUT=3600
LAIN5G_IMAGE_PULL_ENABLED=true
LAIN5G_LOG_TAIL_LINES=500
LAIN5G_MAX_OUTPUT_CHARS=20000
LAIN5G_CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
LAIN5G_OPEN5GS_MONGO_URI=mongodb://mongo:27017/open5gs
LAIN5G_OPEN5GS_MONGO_DATABASE=open5gs
LAIN5G_OPEN5GS_SUBSCRIBER_COLLECTION=subscribers
LAIN5G_SUBSCRIBER_SECRETS_VISIBLE=false
LAIN5G_SUBSCRIBER_OPERATION_TIMEOUT=15
LAIN5G_OPEN5GS_DOCKER_NETWORK=lain5g-lab-5g-sa-core
LAIN5G_RF_WEB_CONTROL_ENABLED=false

APP_FRONTEND_PORT=8080
APP_BACKEND_PORT=8000
